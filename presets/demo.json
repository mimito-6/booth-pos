    { "id": "c-print",   "name": "明信片組",   "description": "透卡 + 珠光 各 1", "price":  10, "uses": [{ "productId": "p-prt-clear", "qty": 1 }, { "productId": "p-prt-pearl", "qty": 1 }], "sortOrder": 0 },
    { "id": "c-acrylic", "name": "壓克力組合", "description": "吊飾 + 立牌",       "price": 100, "uses": [{ "productId": "p-acr-charm", "qty": 1 }, { "productId": "p-acr-stand", "qty": 1 }], "sortOrder": 1 }
